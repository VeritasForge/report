# Environment variables
.env

# MCP server config (contains API tokens)
.mcp.json

# Cron: rendered crontab (absolute paths) + backup are machine-specific; template is committed
deploy/report.crontab
deploy/crontab.backup

# Runtime logs (cron output)
logs/

# IDE settings
.idea/

# Python cache
__pycache__/
*.pyc

# Virtual environment
.venv/

# Coverage
.coverage
htmlcov/

# Docs
docs/*
docs/superpowers/

# Regression test outputs (raw runs are not version-controlled)
# fixtures/ and scripts/ are committed; runs/ contains generated outputs only
tests/regression/runs/
